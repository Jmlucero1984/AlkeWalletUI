<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.AlkeWallet" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="colorPrimary">@color/lightblue</item>
    </style>

    <style name="CustomAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/orange</item>
        <item name="colorOnSurface">@color/green</item>
        <item name="android:dialogCornerRadius" tools:targetApi="28">16dp</item>

        <item name="android:backgroundTint">@color/lightblue</item>
        <item name="android:textColor">#CE3406</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/CustomNegativeButton</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/CustomPositiveButton</item>

    </style>
    <style name="CustomShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item> <!-- acá controlás el radius -->
    </style>

    <style name="CustomNegativeButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/lightgray</item>
        <item name="textFillColor">#673AB7</item>
    </style>
    <style name="CustomPositiveButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#FFFFFF</item>
        <item name="textFillColor">#FFEB3B</item>

    </style>







</resources>